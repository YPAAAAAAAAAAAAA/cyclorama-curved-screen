<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Cyclorama</AssemblyName>
    <RootNamespace>Cyclorama</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4022.49" />
  </ItemGroup>
  <ItemGroup>
    <!-- Ship the demo assets next to the exe so the no-argument default just works. -->
    <Content Include="samples\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
